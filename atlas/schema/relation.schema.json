{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/atlas/schema/relation.schema.json",
  "title": "RelationSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "source_domain_id",
    "target_domain_id",
    "relation_type",
    "conditions",
    "preserved",
    "lost",
    "expected_effect",
    "must_fail_tests",
    "citations",
    "status"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "source_domain_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "target_domain_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "relation_type": {
      "type": "string",
      "enum": [
        "approximation_limit",
        "coarse_graining",
        "regime_shift",
        "model_reduction",
        "measurement_mapping",
        "equivalence_mapping",
        "composition",
        "coupling",
        "aggregation_rule"
      ]
    },
    "conditions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "params"],
      "properties": {
        "text": {"type": "string"},
        "params": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "integer", "boolean", "null"]
          }
        }
      }
    },
    "preserved": {"type": "array", "items": {"type": "string"}},
    "lost": {"type": "array", "items": {"type": "string"}},
    "expected_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direction", "description"],
      "properties": {
        "direction": {"type": "string", "enum": ["increase", "decrease", "context_dependent", "unknown"]},
        "inequality": {"type": "string"},
        "description": {"type": "string"}
      }
    },
    "must_fail_tests": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/testSpec"}},
    "citations": {"type": "array", "items": {"$ref": "#/$defs/citationSpec"}, "minItems": 1},
    "status": {"type": "string", "enum": ["draft", "review", "stable"]},
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tags": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}
        },
        "notes": {"type": "string"}
      }
    },
    "parts": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}
    }
  },
  "$defs": {
    "testSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "expected_outcome", "rationale", "citations", "severity"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "statement": {"type": "string"},
        "expected_outcome": {"type": "string"},
        "rationale": {"type": "string"},
        "citations": {"type": "array", "items": {"type": "string"}},
        "severity": {"type": "string", "enum": ["hard", "soft"]}
      }
    },
    "citationSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "ref"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "type": {"type": "string", "enum": ["doi", "url", "book", "report", "note", "other"]},
        "ref": {"type": "string"},
        "title": {"type": "string"},
        "year": {"type": "integer"},
        "authors": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
