{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/atlas/schema/relation.schema.json",
  "title": "RelationSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "source_domain_id",
    "target_domain_id",
    "relation_type",
    "conditions",
    "preserved",
    "lost",
    "expected_effect",
    "must_fail_tests",
    "citations",
    "status"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "source_domain_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "target_domain_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "relation_type": {
      "type": "string",
      "enum": [
        "approximation_limit",
        "coarse_graining",
        "regime_shift",
        "model_reduction",
        "measurement_mapping",
        "equivalence_mapping",
        "composition",
        "coupling",
        "aggregation_rule"
      ]
    },
    "conditions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "params"],
      "properties": {
        "text": {"type": "string"},
        "params": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "integer", "boolean", "null"]
          }
        }
      }
    },
    "preserved": {"type": "array", "items": {"type": "string"}},
    "lost": {"type": "array", "items": {"type": "string"}},
    "expected_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direction", "description"],
      "properties": {
        "direction": {"type": "string", "enum": ["increase", "decrease", "context_dependent", "unknown"]},
        "inequality": {"type": "string"},
        "description": {"type": "string"}
      }
    },
    "must_fail_tests": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/testSpec"}},
    "citations": {"type": "array", "items": {"$ref": "#/$defs/citationSpec"}, "minItems": 1},
    "status": {"type": "string", "enum": ["draft", "review", "stable"]},
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tags": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}
        },
        "notes": {"type": "string"}
      }
    },
    "channels": {
      "type": "array",
      "description": "Coupling/exchange channels (heat, work, mass, information, etc.)",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}
    },
    "composition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "parts"],
      "properties": {
        "kind": {"type": "string", "enum": ["subsystem_of", "component_of", "module_of"]},
        "parts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["domain_ref"],
            "properties": {
              "domain_ref": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
              "role": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
              "weight": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}
            }
          }
        },
        "notes": {"type": "string"}
      }
    },
    "aggregation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_quantity", "rule_kind", "statement"],
      "properties": {
        "target_quantity": {
          "type": "string",
          "enum": [
            "entropy_production",
            "entropy_flow",
            "entropy_storage",
            "free_energy",
            "information_rate",
            "other"
          ]
        },
        "rule_kind": {
          "type": "string",
          "enum": [
            "additive",
            "subadditive",
            "superadditive",
            "upper_bound",
            "lower_bound",
            "inequality",
            "noncomposable"
          ]
        },
        "statement": {
          "type": "object",
          "additionalProperties": false,
          "required": ["text"],
          "properties": {
            "text": {"type": "string"},
            "latex": {"type": "string"}
          }
        },
        "conditions": {"type": "string"},
        "failure_modes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "regime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["breaks_assumptions"],
      "properties": {
        "breaks_assumptions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "new_assumptions": {"type": "array", "items": {"type": "string"}},
        "singular_limit": {"type": "boolean"}
      }
    },
    "parts": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"relation_type": {"const": "composition"}}, "required": ["relation_type"]},
      "then": {"required": ["composition"]}
    },
    {
      "if": {"required": ["composition"]},
      "then": {"properties": {"relation_type": {"const": "composition"}}}
    },
    {
      "if": {"properties": {"relation_type": {"const": "aggregation_rule"}}, "required": ["relation_type"]},
      "then": {"required": ["aggregation"]}
    },
    {
      "if": {"required": ["aggregation"]},
      "then": {"properties": {"relation_type": {"const": "aggregation_rule"}}}
    },
    {
      "if": {"required": ["regime"]},
      "then": {"properties": {"relation_type": {"const": "regime_shift"}}}
    },
    {
      "if": {"properties": {"relation_type": {"const": "regime_shift"}}, "required": ["relation_type"]},
      "then": {"required": ["regime"]}
    }
  ],
  "$defs": {
    "testSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "expected_outcome", "rationale", "citations", "severity"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "statement": {"type": "string"},
        "expected_outcome": {"type": "string"},
        "rationale": {"type": "string"},
        "citations": {"type": "array", "items": {"type": "string"}},
        "severity": {"type": "string", "enum": ["hard", "soft"]}
      }
    },
    "citationSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "ref"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "type": {"type": "string", "enum": ["doi", "url", "book", "report", "note", "other"]},
        "ref": {"type": "string"},
        "title": {"type": "string"},
        "year": {"type": "integer"},
        "authors": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
