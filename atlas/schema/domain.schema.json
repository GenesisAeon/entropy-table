{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/atlas/schema/domain.schema.json",
  "title": "Entropy Atlas Domain",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "domain",
    "system_type",
    "entropy_quantity_kind",
    "epistemic_status",
    "scope",
    "entropy_proxy",
    "spectral_bands",
    "operators",
    "bands",
    "must_fail_tests",
    "citations",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "system_type": {
      "type": "string",
      "minLength": 1
    },
    "entropy_quantity_kind": {
      "type": "string",
      "enum": [
        "production_rate",
        "entropy_flux",
        "state_entropy",
        "budget_entropy",
        "proxy_other"
      ]
    },
    "epistemic_status": {
      "type": "string",
      "enum": [
        "theorem",
        "empirical",
        "numerical",
        "heuristic",
        "disputed",
        "open_problem"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applies_to",
        "does_not_apply"
      ],
      "properties": {
        "applies_to": {
          "type": "string",
          "minLength": 1
        },
        "does_not_apply": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "entropy_proxy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "symbol",
        "definition_latex",
        "units",
        "estimation_method"
      ],
      "properties": {
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "definition_latex": {
          "type": "string",
          "minLength": 1
        },
        "units": {
          "type": "string",
          "minLength": 1
        },
        "estimation_method": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "spectral_bands": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "phi_definition_latex",
        "bands"
      ],
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1
        },
        "phi_definition_latex": {
          "type": "string",
          "minLength": 1
        },
        "bands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "operators": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "triggers",
        "dampers"
      ],
      "properties": {
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "dampers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "bands": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "beta",
        "theta"
      ],
      "properties": {
        "beta": {
          "$ref": "#/$defs/bandSpec"
        },
        "theta": {
          "$ref": "#/$defs/bandSpec"
        }
      }
    },
    "must_fail_tests": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "stable"
      ]
    }
  },
  "$defs": {
    "bandSpec": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        {
          "required": [
            "range"
          ]
        },
        {
          "required": [
            "distribution"
          ]
        }
      ],
      "properties": {
        "range": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "number"
          }
        },
        "distribution": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
